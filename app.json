{
  "expo": {
    "name": "Whagons",
    "slug": "whagons",
    "version": "5.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/whagons-check.png",
      "resizeMode": "contain",
      "backgroundColor": "#121614"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whagons.v5",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A3B30"
      },
      "package": "com.whagons.v5",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "./node_modules/@react-native-firebase/app/app.plugin.js",
      "./node_modules/@react-native-firebase/auth/app.plugin.js",
      "./node_modules/@react-native-firebase/messaging/app.plugin.js",
      "@react-native-google-signin/google-signin",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Whagons to access your camera to scan barcodes."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Whagons to use your location to map spots and rooms.",
          "locationWhenInUsePermission": "Allow Whagons to use your location to map spots and rooms."
        }
      ]
    ]
  }
}