{
  "expo": {
    "name": "Whagons",
    "slug": "whagons",
    "scheme": "whagons",
    "version": "5.1.26",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121614"
    },
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "buildNumber": "42",
      "bundleIdentifier": "com.whagons.v5",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:cvx-share-dev.whagons.com",
        "applinks:cvx-share.whagons.com",
        "applinks:whagons.com",
        "applinks:app.whagons.com",
        "applinks:*.app.whagons.com",
        "applinks:*.dev.whagons.com",
        "applinks:*.whagons.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Whagons to access your camera for video calls and barcode scanning.",
        "NSMicrophoneUsageDescription": "Allow Whagons to use your microphone for voice calls, video calls, and voice task drafts.",
        "NFCReaderUsageDescription": "Allow Whagons to program and read NFC task tags."
      }
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C82828"
      },
      "package": "com.whagons.v5",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "adjustResize",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "NFC"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "cvx-share-dev.whagons.com",
              "pathPrefix": "/nfc/tap"
            },
            {
              "scheme": "https",
              "host": "cvx-share.whagons.com",
              "pathPrefix": "/nfc/tap"
            },
            {
              "scheme": "https",
              "host": "whagons.com",
              "pathPrefix": "/nfc/tap"
            },
            {
              "scheme": "https",
              "host": "whagons.com",
              "pathPrefix": "/nfc/program"
            },
            {
              "scheme": "https",
              "host": "app.whagons.com",
              "pathPrefix": "/nfc/tap"
            },
            {
              "scheme": "https",
              "host": "app.whagons.com",
              "pathPrefix": "/nfc/program"
            },
            {
              "scheme": "https",
              "host": "*.app.whagons.com",
              "pathPrefix": "/nfc/tap"
            },
            {
              "scheme": "https",
              "host": "*.app.whagons.com",
              "pathPrefix": "/nfc/program"
            },
            {
              "scheme": "https",
              "host": "*.dev.whagons.com",
              "pathPrefix": "/nfc/tap"
            },
            {
              "scheme": "https",
              "host": "*.dev.whagons.com",
              "pathPrefix": "/nfc/program"
            },
            {
              "scheme": "https",
              "host": "*.whagons.com",
              "pathPrefix": "/nfc/tap"
            },
            {
              "scheme": "https",
              "host": "*.whagons.com",
              "pathPrefix": "/nfc/program"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "./node_modules/@react-native-firebase/app/app.plugin.js",
      "./node_modules/@react-native-firebase/auth/app.plugin.js",
      "./node_modules/@react-native-firebase/messaging/app.plugin.js",
      "@react-native-google-signin/google-signin",
      "react-native-nfc-manager",
      "expo-apple-authentication",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Montserrat_400Regular.ttf",
            "./assets/fonts/Montserrat_500Medium.ttf",
            "./assets/fonts/Montserrat_600SemiBold.ttf",
            "./assets/fonts/Montserrat_700Bold.ttf",
            "./assets/fonts/AntDesign.ttf",
            "./assets/fonts/Entypo.ttf",
            "./assets/fonts/EvilIcons.ttf",
            "./assets/fonts/Feather.ttf",
            "./assets/fonts/FontAwesome.ttf",
            "./assets/fonts/FontAwesome5_Brands.ttf",
            "./assets/fonts/FontAwesome5_Regular.ttf",
            "./assets/fonts/FontAwesome5_Solid.ttf",
            "./assets/fonts/FontAwesome6_Brands.ttf",
            "./assets/fonts/FontAwesome6_Regular.ttf",
            "./assets/fonts/FontAwesome6_Solid.ttf",
            "./assets/fonts/Fontisto.ttf",
            "./assets/fonts/Foundation.ttf",
            "./assets/fonts/Ionicons.ttf",
            "./assets/fonts/MaterialCommunityIcons.ttf",
            "./assets/fonts/MaterialIcons.ttf",
            "./assets/fonts/Octicons.ttf",
            "./assets/fonts/SimpleLineIcons.ttf",
            "./assets/fonts/Zocial.ttf"
          ]
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Whagons to use your microphone for voice calls, video calls, and voice task drafts."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Whagons to access your camera for video calls and barcode scanning."
        }
      ],
      "./node_modules/@config-plugins/react-native-webrtc/app.plugin.js",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Whagons to use your location to map spots and rooms.",
          "locationWhenInUsePermission": "Allow Whagons to use your location to map spots and rooms."
        }
      ],
      "expo-video",
      "./plugins/withNotifee.js",
      "./plugins/withIosFirebasePodfileFix.js",
      "./plugins/withIosVersionFromAppJson.js",
      "expo-localization",
      [
        "expo-asset",
        {
          "assets": [
            "./assets/notification-sounds"
          ]
        }
      ]
    ]
  }
}